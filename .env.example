# ── Accurity REST API ──────────────────────────────────────────────────────
ACCURITY_BASE_URL=https://app.accurity.ai
ACCURITY_AUTH_URL=https://<AUTH_SERVER_HOST>/auth/realms/accurity/protocol/openid-connect/token
ACCURITY_USERNAME=your_username
ACCURITY_PASSWORD=your_password

# ── MCP server transport ───────────────────────────────────────────────────
# Options: stdio (default) | http
MCP_TRANSPORT=http
# Required when MCP_TRANSPORT=http
MCP_PORT=8001
MCP_HOST=0.0.0.0

# ── LLM (llama.cpp) ────────────────────────────────────────────────────────
LLAMA_BASE_URL=http://localhost:8080
# Model name passed to ChatOpenAI — llama.cpp ignores it, but some
# OpenAI-compatible wrappers use it for routing.
LLM_MODEL=local
# Sampling temperature (0 = deterministic)
LLM_TEMPERATURE=0

# ── Flask backend ──────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change_me_in_production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
DATABASE_URL=sqlite:///chat_history.db

# ── Webapp → MCP connection ────────────────────────────────────────────────
# URL of the running MCP server (must use http transport)
MCP_SERVER_URL=http://localhost:8001

# ── Frontend (Express) ─────────────────────────────────────────────────────
# Port the Express server listens on
PORT=3000
# URL of the Flask backend — the Express server proxies /api here
BACKEND_URL=http://localhost:5000
