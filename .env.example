# Accurity REST API
ACCURITY_BASE_URL=https://app.accurity.ai
ACCURITY_AUTH_URL=https://<AUTH_SERVER_HOST>/auth/realms/accurity/protocol/openid-connect/token
ACCURITY_USERNAME=your_username
ACCURITY_PASSWORD=your_password

# MCP server transport
# Options: stdio (default) | http
MCP_TRANSPORT=stdio
# Required when MCP_TRANSPORT=http
MCP_PORT=8001
MCP_HOST=0.0.0.0

# LLM
LLAMA_BASE_URL=http://localhost:8080

# Flask
FLASK_SECRET_KEY=change_me
DATABASE_URL=sqlite:///chat_history.db
